{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Screen YAML Schema",
  "description": "JSON Schema для валидации YAML-описания демо-экранов Skala DS",
  "type": "object",
  "required": ["meta", "content"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["breadcrumbs"],
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "breadcrumbs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["label"],
            "properties": {
              "label": { "type": "string" }
            }
          }
        }
      }
    },
    "sidebar": {
      "type": "object",
      "properties": {
        "logoVariant": {
          "type": "string",
          "enum": ["genom", "vision", "spektr", "spektr-s3", "spektr-ai"]
        },
        "avatarInitials": { "type": "string", "maxLength": 3 },
        "statusVariant": {
          "type": "string",
          "enum": ["default", "lock"]
        },
        "menuSections": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["items"],
            "properties": {
              "title": { "type": "string" },
              "items": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["icon", "label"],
                  "properties": {
                    "icon": { "type": "string" },
                    "label": { "type": "string" },
                    "active": { "type": "boolean" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "content": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type"],
        "oneOf": [
          {
            "properties": {
              "type": { "const": "section" },
              "heading": { "type": "string" },
              "direction": { "type": "string", "enum": ["row", "col"] },
              "gap": { "type": "number", "minimum": 0 },
              "items": { "type": "array" }
            },
            "required": ["items"]
          },
          {
            "properties": {
              "type": { "const": "row" },
              "gap": { "type": "number", "minimum": 0 },
              "items": { "type": "array" }
            },
            "required": ["items"]
          },
          {
            "properties": {
              "type": { "const": "col" },
              "gap": { "type": "number", "minimum": 0 },
              "items": { "type": "array" }
            },
            "required": ["items"]
          },
          {
            "properties": {
              "type": { "const": "button" },
              "label": { "type": "string" },
              "sentiment": { "type": "string", "enum": ["accent", "danger", "warning", "success", "info", "secondary"] },
              "filled": { "type": "boolean" },
              "outline": { "type": "boolean" },
              "size": { "type": "string", "enum": ["large", "small"] },
              "icon": { "type": "string" },
              "iconPosition": { "type": "string", "enum": ["left", "right", "icon-only"] },
              "disabled": { "type": "boolean" },
              "state": { "type": "string", "enum": ["default", "hover", "focus", "active", "disabled"] }
            },
            "required": ["label"]
          },
          {
            "properties": {
              "type": { "const": "badge" },
              "label": { "type": "string" },
              "color": { "type": "string", "enum": ["gray", "gray-strong", "gray-warm", "nile-blue", "tory-blue", "cornflower-blue", "bondi-blue", "java", "green", "shamrock", "yellow", "orange", "red", "rose", "violet"] },
              "content": { "type": "string", "enum": ["text-only", "text-and-icon", "outline"] },
              "icon": { "type": "string" }
            },
            "required": ["label"]
          },
          {
            "properties": {
              "type": { "const": "input" },
              "placeholder": { "type": "string" },
              "state": { "type": "string", "enum": ["default", "warning", "error", "disabled"] },
              "label": { "type": "string" },
              "hint": { "type": "string" },
              "icon": { "type": "string" },
              "iconPosition": { "type": "string", "enum": ["left", "right"] },
              "inputType": { "type": "string" },
              "value": { "type": "string" }
            }
          },
          {
            "properties": {
              "type": { "const": "textarea" },
              "placeholder": { "type": "string" },
              "state": { "type": "string", "enum": ["default", "warning", "error", "disabled"] },
              "label": { "type": "string" },
              "hint": { "type": "string" },
              "value": { "type": "string" },
              "copyText": { "type": "boolean" }
            }
          },
          {
            "properties": {
              "type": { "const": "tablestatus" },
              "label": { "type": "string" },
              "severity": { "type": "string", "enum": ["success", "degradation", "warning", "critical", "info", "maintenance", "additional", "stop", "new", "load"] },
              "size": { "type": "number", "enum": [17, 24] },
              "content": { "type": "string", "enum": ["text-only", "text-and-icon", "icon-only", "outline-text-only"] },
              "icon": { "type": "string" }
            }
          },
          {
            "properties": {
              "type": { "const": "text" },
              "content": { "type": "string" },
              "variant": { "type": "string", "enum": ["body", "caption", "subtle"] }
            },
            "required": ["content"]
          },
          {
            "properties": {
              "type": { "const": "heading" },
              "content": { "type": "string" },
              "level": { "type": "number", "enum": [2, 3] }
            },
            "required": ["content"]
          },
          {
            "properties": {
              "type": { "const": "dropdown" },
              "placeholder": { "type": "string" },
              "state": { "type": "string", "enum": ["default", "warning", "error", "disabled"] },
              "label_dropdown": { "type": "string" },
              "hint": { "type": "string" },
              "options": { "type": "array", "items": { "type": "object", "required": ["label", "value"], "properties": { "label": { "type": "string" }, "value": { "type": "string" } } } },
              "value": { "type": "string" }
            }
          },
          {
            "properties": {
              "type": { "const": "datatable" },
              "columns": { "type": "array" },
              "data": { "type": "array" },
              "generateRows": { "type": "number", "minimum": 0 },
              "selectable": { "type": "boolean" },
              "pageSize": { "type": "number", "minimum": 1 },
              "searchPlaceholder": { "type": "string" },
              "toolbarActions": { "type": "array" },
              "bulkActions": { "type": "array" },
              "filterChips": { "type": "array" }
            },
            "required": ["columns"]
          },
          {
            "properties": {
              "type": { "const": "modal-trigger" },
              "buttonLabel": { "type": "string" },
              "buttonSentiment": { "type": "string" },
              "buttonSize": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "width": { "type": "number", "enum": [400, 600, 800, 960] },
              "content": { "type": "array" },
              "footerButtons": { "type": "array" }
            },
            "required": ["buttonLabel", "title", "content"]
          },
          {
            "properties": {
              "type": { "const": "drawer-trigger" },
              "buttonLabel": { "type": "string" },
              "buttonSentiment": { "type": "string" },
              "buttonSize": { "type": "string" },
              "title": { "type": "string" },
              "width": { "type": "number", "enum": [400, 600, 800, 960] },
              "backdrop": { "type": "boolean" },
              "content": { "type": "array" },
              "footerButtons": { "type": "array" }
            },
            "required": ["buttonLabel", "title", "content"]
          },
          {
            "properties": {
              "type": { "const": "form" },
              "gap": { "type": "number", "minimum": 0 },
              "items": { "type": "array" }
            },
            "required": ["items"]
          }
        ]
      }
    }
  }
}
